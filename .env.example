PORT=9502
HOST=0.0.0.0

# Uncomment ONE of these integration modes:

# 1. Live Hermes Agent status API (preferred)
# HERMES_AGENT_API=http://localhost:8080/api/agents/status

# 2. Static JSON file drop from Hermes cron/scripts
# AGENTS_JSON_PATH=./agents.json

# Polling interval for HERMES_AGENT_API
POLL_INTERVAL_SECONDS=5

# Server-Sent Events for live browser updates
ENABLE_SSE=true
