# Hermes 3D Office Dashboard — Environment Configuration
#
# Copy this file to .env and edit as needed.
# The dashboard works with zero config (demo mode) or with any of these:

# --- Bridge Script (recommended) ---
# The bridge script auto-discovers your Hermes agents and writes agents.json.
# Run it in watch mode to keep the dashboard live:
#   python3 scripts/hermes_bridge.py --watch --interval 10
# No .env config needed — it reads from ~/.hermes/ automatically.

# --- Gateway Port (optional) ---
# If your Hermes gateway runs on a non-default port, set this:
# GATEWAY_PORT=51763

# --- Server Settings ---
PORT=9502
HOST=0.0.0.0

# --- Hermes API Mode (optional, alternative to bridge) ---
# Point this to your Hermes gateway snapshot endpoint:
# HERMES_AGENT_API=http://localhost:51763/api/snapshot

# --- JSON File Mode (automatic when agents.json exists) ---
# The bridge script writes here by default:
# AGENTS_JSON_PATH=./agents.json

# --- Polling ---
POLL_INTERVAL_SECONDS=5

# --- Server-Sent Events (live browser updates) ---
ENABLE_SSE=true